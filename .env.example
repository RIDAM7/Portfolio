# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Public site URL, no trailing slash. Powers metadataBase, the canonical URL,
# OG/Twitter image URLs, robots.txt and sitemap.xml. Set this to your real
# production URL (e.g. https://ridam.vercel.app or your custom domain).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key (https://resend.com → API Keys). Starts with "re_".
RESEND_API_KEY=

# Destination address for contact-form messages. While sending from Resend's
# shared sender (onboarding@resend.dev), this must be your Resend account email.
# Verify a custom domain in Resend to send to any address.
CONTACT_TO_EMAIL=
